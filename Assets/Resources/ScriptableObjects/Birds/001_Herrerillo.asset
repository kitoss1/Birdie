  m_Script: {fileID: 11500000, guid: 70219269baca5b648af64fe42e11e0ed, type: 3}
  m_Name: 001_Herrerillo
  m_EditorClassIdentifier: Assembly-CSharp::Birdie.Data.BirdData
  m_birdName: "Herrerillo com\xFAn"
  m_scientificName: Cyanistes caeruleus
  m_birdID: 001
  m_basicDescription: "Peque\xF1o, ruidoso y con un estilo inconfundible: azul y
    amarillo de la cabeza a la cola, como si hubiera elegido su outfit con mucho
    criterio. Es de los p\xE1jaros m\xE1s activos que puedes encontrar, siempre movi\xE9ndose,
    siempre con algo que decir.\nLe gustan los bosques, pero tambi\xE9n se deja ver
    por los parques sin ning\xFAn problema. A la hora de buscar casa no es nada exigente:
    un hueco en un \xE1rbol, una grieta en la pared o una caja-nido le van igual
    de bien. Con tal de que sea suyo.\nNo es de extra\xF1ar que sea uno de los p\xE1jaros
    m\xE1s queridos y extendidos de la zona."
  m_birdPrefab: {fileID: 7991333266149840317, guid: 6b1cbfbf7eaa6814d91394694816c7e5, type: 3}
  m_birdPhoto: {fileID: 21300000, guid: 55c815fe8a58fa445b7802a8efda42aa, type: 3}
